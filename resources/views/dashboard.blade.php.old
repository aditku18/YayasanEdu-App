                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [{
                    label: 'Revenue (Million Rp)',
                    data: [45, 52, 48, 65, 72, 85],
                    backgroundColor: 'rgba(16, 185, 129, 0.8)',
                    borderRadius: 8
