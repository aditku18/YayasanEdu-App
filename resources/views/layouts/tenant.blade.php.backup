        <style>
            .bg-sidebar {
                background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            }
            .sidebar-link {
                @apply flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-slate-300 rounded-lg transition-colors hover:bg-white/5 hover:text-white;
            }
            .sidebar-link.active {
                @apply bg-blue-500/20 text-blue-400;
            }
            .glass-card {
                @apply bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl;
            }
            @keyframes float {
                0%, 100% { transform: translateY(0px); }
                50% { transform: translateY(-20px); }
            }
            .animate-float {
                animation: float 6s ease-in-out infinite;
            }
            @keyframes slide-up {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            .animate-slide-up {
                animation: slide-up 0.5s ease-out;
            }
            @keyframes fade-in {
                from { opacity: 0; }
                to { opacity: 1; }
            }
            .animate-fade-in {
                animation: fade-in 0.5s ease-out;
            }
        </style>
